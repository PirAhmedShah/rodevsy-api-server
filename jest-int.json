{
  "moduleFileExtensions": ["json", "js", "ts"],
  "rootDir": "src",
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/$1"
  },
  "testRegex": ".*\\.integration\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "@swc/jest"
  },
  "transformIgnorePatterns": ["node_modules/(?!.*jose)"],
  "collectCoverageFrom": ["**/*.(t|j)s"],
  "coverageDirectory": "../coverage-int",
  "testEnvironment": "node"
}
