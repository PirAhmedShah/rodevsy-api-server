### ---- ENVIRONMENT ----
NODE_ENV=development
### ---- SERVER ---- 
PORT=8080
MAX_HEAP_THRESHOLD_MB=300
### ---- DATABASE ---- 
DB_HOST=localhost 
DB_PORT=5432
DB_PASSWORD_FILE=./dummy/secrets/db_password.secret
DB_USER=postgres
DB_NAME=dev
DB_POOL_MIN_CONNECTIONS=5
DB_POOL_MAX_CONNECTIONS=100
### ---- JWT CONFIG ---- 
JWT_PUBLIC_FILE=./dummy/secrets/jwt_public.pem
JWT_PRIVATE_FILE=./dummy/secrets/jwt_private.pem
# JWT_EXPIRATION=3600
JWT_ISSUER=http://localhost:8080
JWT_AUDIENCE=API
### ---- REDIS CONFIG ---- 
CACHE_HOST=localhost
CACHE_PORT=6379
CACHE_PASSWORD_FILE=./dummy/secrets/cache_password.secret
CACHE_POOL_MIN_CONNECTIONS=5
CACHE_POOL_MAX_CONNECTIONS=100
### ---- DBMATE CONFIG ----
MIGRATIONS_DIR="./migrations"